{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "title": "Backend Overview",
  "uid": "backend-overview",
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1, "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "title": "Total RPS",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(rate(http_server_requests_seconds_count{job=\"eduquest-backend\"}[1m]))",
        "legendFormat": "RPS",
        "refId": "A"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "reqps", "thresholds": {
        "mode": "absolute",
        "steps": [{"color":"green","value":null},{"color":"yellow","value":50},{"color":"red","value":200}]
      }}}
    },
    {
      "id": 2, "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "title": "Error Rate",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(rate(http_server_requests_seconds_count{job=\"eduquest-backend\",status=~\"5..\"}[1m])) / sum(rate(http_server_requests_seconds_count{job=\"eduquest-backend\"}[1m])) * 100",
        "legendFormat": "Error %",
        "refId": "A"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": {
        "mode": "absolute",
        "steps": [{"color":"green","value":null},{"color":"yellow","value":1},{"color":"red","value":5}]
      }}}
    },
    {
      "id": 3, "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "title": "Mean Response Time",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(rate(http_server_requests_seconds_sum{job=\"eduquest-backend\"}[1m])) / sum(rate(http_server_requests_seconds_count{job=\"eduquest-backend\"}[1m]))",
        "legendFormat": "Mean",
        "refId": "A"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": {
        "mode": "absolute",
        "steps": [{"color":"green","value":null},{"color":"yellow","value":0.5},{"color":"red","value":2}]
      }}}
    },
    {
      "id": 4, "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "title": "CPU Usage",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "process_cpu_usage{job=\"eduquest-backend\"} * 100",
        "legendFormat": "CPU",
        "refId": "A"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": {
        "mode": "absolute",
        "steps": [{"color":"green","value":null},{"color":"yellow","value":60},{"color":"red","value":85}]
      }}}
    },
    {
      "id": 5, "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "title": "Memory Usage",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(jvm_memory_used_bytes{job=\"eduquest-backend\"})",
        "legendFormat": "Used",
        "refId": "A"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "bytes", "thresholds": {
        "mode": "absolute",
        "steps": [{"color":"green","value":null},{"color":"yellow","value":400000000},{"color":"red","value":700000000}]
      }}}
    },
    {
      "id": 6, "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "title": "Uptime",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "process_uptime_seconds{job=\"eduquest-backend\"}",
        "legendFormat": "Uptime",
        "refId": "A"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 7, "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "title": "Request Rate by Endpoint",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum by (uri, method) (rate(http_server_requests_seconds_count{job=\"eduquest-backend\"}[1m]))",
        "legendFormat": "{{method}} {{uri}}",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 8, "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "title": "Response Time Percentiles (p50 / p95 / p99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=\"eduquest-backend\"}[1m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"eduquest-backend\"}[1m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"eduquest-backend\"}[1m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 9, "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "title": "HTTP Errors (4xx / 5xx)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"eduquest-backend\",status=~\"4..\"}[1m]))",
          "legendFormat": "4xx",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"eduquest-backend\",status=~\"5..\"}[1m]))",
          "legendFormat": "5xx",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 10, "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "title": "JVM Memory (Heap / Non-Heap)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(jvm_memory_used_bytes{job=\"eduquest-backend\", area=\"heap\"})",
          "legendFormat": "Heap Used",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(jvm_memory_max_bytes{job=\"eduquest-backend\", area=\"heap\"})",
          "legendFormat": "Heap Max",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(jvm_memory_used_bytes{job=\"eduquest-backend\", area=\"nonheap\"})",
          "legendFormat": "Non-Heap",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "id": 11, "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "title": "DB Connection Pool (HikariCP)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_active{job=\"eduquest-backend\"}",
          "legendFormat": "Active",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_idle{job=\"eduquest-backend\"}",
          "legendFormat": "Idle",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_pending{job=\"eduquest-backend\"}",
          "legendFormat": "Pending",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_max{job=\"eduquest-backend\"}",
          "legendFormat": "Max",
          "refId": "D"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 12, "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "title": "DB Query Time (HikariCP)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(hikaricp_connections_usage_seconds_sum{job=\"eduquest-backend\"}[1m]) / rate(hikaricp_connections_usage_seconds_count{job=\"eduquest-backend\"}[1m])",
          "legendFormat": "Avg Connection Usage",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(hikaricp_connections_acquire_seconds_sum{job=\"eduquest-backend\"}[1m]) / rate(hikaricp_connections_acquire_seconds_count{job=\"eduquest-backend\"}[1m])",
          "legendFormat": "Avg Acquire Time",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 13, "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "title": "Thread Pool",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "jvm_threads_live_threads{job=\"eduquest-backend\"}",
          "legendFormat": "Live",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "jvm_threads_daemon_threads{job=\"eduquest-backend\"}",
          "legendFormat": "Daemon",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "jvm_threads_peak_threads{job=\"eduquest-backend\"}",
          "legendFormat": "Peak",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 14, "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "title": "GC Pause Time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "rate(jvm_gc_pause_seconds_sum{job=\"eduquest-backend\"}[1m])",
        "legendFormat": "{{action}} {{cause}}",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 15, "gridPos": { "h": 8, "w": 24, "x": 0, "y": 36 },
      "title": "Max / Mean Response Time by Endpoint",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(20, max by (uri, method) (rate(http_server_requests_seconds_max{job=\"eduquest-backend\"}[5m])))",
          "legendFormat": "{{method}} {{uri}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": { "sortBy": [{ "displayName": "Value", "desc": true }] },
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}
